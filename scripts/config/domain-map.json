{
  "rules": [
    {
      "domain": "ui",
      "prefixes": [
        "components/",
        "styles/",
        "public/"
      ],
      "exact": []
    },
    {
      "domain": "routing",
      "prefixes": [
        "app/"
      ],
      "exact": []
    },
    {
      "domain": "domain",
      "prefixes": [
        "lib/"
      ],
      "exact": []
    },
    {
      "domain": "audit",
      "prefixes": [
        ".agents/plans/"
      ],
      "exact": []
    },
    {
      "domain": "prompts",
      "prefixes": [
        ".agents/prompts/"
      ],
      "exact": []
    },
    {
      "domain": "tooling",
      "prefixes": [
        ".husky/",
        "scripts/"
      ],
      "exact": [
        "package.json",
        "pnpm-lock.yaml",
        "tsconfig.json"
      ]
    },
    {
      "domain": "docs",
      "prefixes": [
        "docs/"
      ],
      "exact": [
        "README.md",
        "CHANGELOG.md",
        "CONTRIBUTING.md",
        "LICENSE",
        "AGENTS.md"
      ]
    }
  ],
  "risk": {
    "high": [
      "tooling",
      "domain",
      "contracts",
      "routing"
    ],
    "medium": [
      "ui",
      "prompts"
    ],
    "low": [
      "audit",
      "docs"
    ]
  }
}
